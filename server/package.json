{
  "name": "lingoflow-server",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon --exec \"node --experimental-strip-types\" src/index.ts",
    "typecheck": "node ../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "build:dist": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && node ../client/node_modules/esbuild/bin/esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --packages=external --minify --sourcemap --outfile=dist/index.js",
    "build": "npm run typecheck && npm run build:dist",
    "start:dist": "node dist/index.js",
    "start": "node --experimental-strip-types src/index.ts",
    "test": "node --experimental-strip-types --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.2",
    "nodemailer": "^8.0.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "overrides": {
    "minimatch": "10.2.3"
  }
}
