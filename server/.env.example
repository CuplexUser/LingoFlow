LINGOFLOW_AUTH_SECRET=change-me-in-production

PUBLIC_APP_URL=http://localhost:5173
EMAIL_FROM=LingoFlow <no-reply@lingoflow.local>

# Optional: Google OAuth2 sign-in
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Optional: SMTP (if omitted, verification links are printed to server logs in dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_SECURE=false

# Optional: community contribution moderation access
# The first registered user is always treated as a reviewer/admin.
# CONTRIBUTION_REVIEWER_EMAILS=reviewer@example.com,second-reviewer@example.com

# Word translation APIs (for hover tooltips in reverse-translation exercises)
# Helsinki-NLP MarianMT via HuggingFace Inference API — get a free token at huggingface.co/settings/tokens
# HUGGINGFACE_API_TOKEN=hf_...
# Optional LibreTranslate fallback — only used if set; point to a self-hosted instance
# LIBRETRANSLATE_URL=https://your-libretranslate-instance.example.com

# Optional: Logging and DB path
# LOG_LEVEL=info
# LINGOFLOW_DB_PATH=./data/lingoflow.db
